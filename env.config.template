# .env file template - Secrets Configuration Reference
#
# IMPORTANT: This is a template file. DO NOT add real secrets here.
#
# For Cloud Run deployment:
#   - Secrets are stored in Google Cloud Secret Manager
#   - Managed via deploy.sh --update-secrets flags
#
# For local development:
#   - Copy this file to env.config
#   - Fill in actual values (DO NOT commit env.config to version control)

# Okta OIDC Secrets
OKTA_DEV_OIDC_SECRET="[REDACTED]"
OKTA_PROD_OIDC_SECRET="[REDACTED]"

# Okta API tokens for token lifetime checks
OKTA_DEV_API_TOKEN="[REDACTED]"
OKTA_PROD_API_TOKEN="[REDACTED]"

# ADFS Client Secrets
ADFS_DEV_CLIENT_SECRET="[REDACTED]"
ADFS_PROD_CLIENT_SECRET="[REDACTED]"

# Flask Application Secret
FLASK_SECRET_KEY="your-flask-secret-key-here"

# Google OIDC (App Login)
GOOGLE_OIDC_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_OIDC_CLIENT_SECRET="[REDACTED]"
GOOGLE_ALLOWED_EMAILS="user1@example.com,user2@example.com"
GOOGLE_ADMIN_EMAILS="admin@example.com"

# Firestore Configuration
FIRESTORE_ALLOWLIST_COLLECTION="app_config"
FIRESTORE_ALLOWLIST_DOC="allowlist"
ALLOWLIST_CACHE_TTL_SECONDS="60"

# Legacy Basic Auth (optional)
BASIC_AUTH_USERNAME="admin"
BASIC_AUTH_PASSWORD="[REDACTED]"
